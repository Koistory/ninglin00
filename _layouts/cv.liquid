---
layout: default
---

<style>
/* Remove markers of CV Education */
.cv ul.card-text.list-group.list-group-flush > li.list-group-item {
  list-style-type: none !important;
}

.cv ul.card-text.list-group.list-group-flush > li.list-group-item::marker {
  content: "" !important;
  font-size: 0 !important;
}

/* Avoid markers of timeline */
.cv ul.timeline > li {
  list-style-type: none !important;
}

.cv ul.timeline > li::marker {
  content: "" !important;
  font-size: 0 !important;
}
</style>

{% assign cv_feature_enabled = site.al_folio.features.cv.enabled | default: true %}

{% if site.plugins contains 'al_folio_cv' and cv_feature_enabled %}
  {% al_folio_cv_render %}
{% else %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description">CV rendering is unavailable.</p>
    </header>
  </div>
{% endif %}

---
layout: default
---

<style>
  /* Remove black bullet markers from top-level CV entries. */
  .cv ul.card-text.list-group.list-group-flush > li.list-group-item {
    list-style-type: none !important;
  }

  .cv ul.card-text.list-group.list-group-flush > li.list-group-item::marker {
    content: "" !important;
    font-size: 0 !important;
  }

  /* Remove black bullet markers from timeline entries. */
  .cv ul.timeline > li {
    list-style-type: none !important;
  }

  .cv ul.timeline > li::marker {
    content: "" !important;
    font-size: 0 !important;
  }

  /* Hide location rows and location icons in CV entries. */
  .cv p.location,
  .cv i.iconlocation {
    display: none !important;
  }

  /* Remove the top and bottom horizontal lines around date badges. */
  .cv .date-column table.table-cv,
  .cv .date-column table.table-cv tbody,
  .cv .date-column table.table-cv tr,
  .cv .date-column table.table-cv td,
  .cv .date-column table.table-cv th {
    border: none !important;
    border-top: none !important;
    border-bottom: none !important;
    box-shadow: none !important;
    background: transparent !important;
  }

  /* Remove possible pseudo-elements around the date table. */
  .cv .date-column table.table-cv::before,
  .cv .date-column table.table-cv::after,
  .cv .date-column table.table-cv td::before,
  .cv .date-column table.table-cv td::after {
    display: none !important;
    content: none !important;
  }

  /* Keep the date badge compact after removing the table borders. */
  .cv .date-column table.table-cv {
    margin: 0 auto !important;
  }

  .cv .date-column table.table-cv td,
  .cv .date-column table.table-cv th {
    padding-top: 0 !important;
    padding-bottom: 0 !important;
  }
</style>

{% assign cv_feature_enabled = site.al_folio.features.cv.enabled | default: true %}

{% if site.plugins contains 'al_folio_cv' and cv_feature_enabled %}
  {% al_folio_cv_render %}
{% else %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description">CV rendering is unavailable.</p>
    </header>
  </div>
{% endif %}
